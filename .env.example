# Copy to .env.local and fill in. All are optional; features stay dormant until set.

# Meta Pixel ID — turns on PageView + ViewContent/Lead/InitiateCheckout tracking.
# Find it in Meta Events Manager. Example: 1234567890
NEXT_PUBLIC_META_PIXEL_ID=

# Newsletter POST endpoint — a hosted form/ESP URL that accepts { email }.
# e.g. a Mailchimp/ConvertKit embedded-form action URL, or a Formspree endpoint.
NEXT_PUBLIC_NEWSLETTER_ENDPOINT=

# Canonical site origin (used by sitemap.xml, robots.txt, JSON-LD).
# Set to your real domain once live, e.g. https://canaceramics.com
NEXT_PUBLIC_SITE_URL=
